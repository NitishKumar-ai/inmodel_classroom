generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  STUDENT
  TEACHER
}

enum SubmissionStatus {
  PENDING
  GRADED
  PLAGIARIZED
}

enum VivaQuestionType {
  MCQ
  SHORT_ANSWER
}

model User {
  id                 String         @id @default(cuid())
  name               String?
  email              String?        @unique
  password           String?
  role               Role           @default(STUDENT)
  onboardingComplete Boolean        @default(false)
  createdAt          DateTime       @default(now())
  courses            Course[]       @relation("TeacherCourses")
  enrollments        Enrollment[]
  submissions        Submission[]
  notifications      Notification[]
  peerReviews        PeerReview[]   @relation("Reviewer")
}

model Course {
  id          String       @id @default(cuid())
  title       String
  description String?
  teacherId   String
  teacher     User         @relation("TeacherCourses", fields: [teacherId], references: [id])
  createdAt   DateTime     @default(now())
  enrollments Enrollment[]
  assignments Assignment[]
}

model Enrollment {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  courseId   String
  course    Course   @relation(fields: [courseId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, courseId])
}

model Assignment {
  id                 String                @id @default(cuid())
  title              String
  description        String
  starterCode        String
  language           String                @default("python")
  difficulty         String?
  hints              Json?
  peerReviewEnabled  Boolean               @default(false)
  isRemedial         Boolean               @default(false)
  parentAssignmentId String?
  parentAssignment   Assignment?           @relation("RemedialOf", fields: [parentAssignmentId], references: [id])
  remedialVersions   Assignment[]          @relation("RemedialOf")
  deadline           DateTime
  courseId            String
  course             Course                @relation(fields: [courseId], references: [id])
  testCases          TestCase[]
  submissions        Submission[]
  peerReviewConfig   PeerReviewAssignment?
  createdAt          DateTime              @default(now())
}

model TestCase {
  id             String     @id @default(cuid())
  assignmentId   String
  assignment     Assignment @relation(fields: [assignmentId], references: [id])
  input          String
  expectedOutput String
  isHidden       Boolean    @default(false)
}

model Submission {
  id              String           @id @default(cuid())
  studentId       String
  student         User             @relation(fields: [studentId], references: [id])
  assignmentId    String
  assignment      Assignment       @relation(fields: [assignmentId], references: [id])
  code            String
  language        String           @default("python")
  score           Float?
  vivaScore       Float?
  peerScore       Float?
  finalScore      Float?
  manualScore     Float?
  manualNote      String?
  testResults     Json?
  flags           Json?
  plagiarismFlags Json?
  status          SubmissionStatus @default(PENDING)
  submittedAt     DateTime         @default(now())
  vivaQuestions   VivaQuestion[]
  vivaResponses   VivaResponse[]
  peerReviews     PeerReview[]
}

model VivaQuestion {
  id            String           @id @default(cuid())
  submissionId  String
  submission    Submission       @relation(fields: [submissionId], references: [id])
  question      String
  type          VivaQuestionType
  options       Json?
  correctAnswer String
  conceptTested String?
  responses     VivaResponse[]
}

model VivaResponse {
  id             String       @id @default(cuid())
  vivaQuestionId String
  vivaQuestion   VivaQuestion @relation(fields: [vivaQuestionId], references: [id])
  submissionId   String
  submission     Submission   @relation(fields: [submissionId], references: [id])
  studentAnswer  String
  isCorrect      Boolean
  aiScore        Int?
  aiFeedback     String?
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String
  message   String
  read      Boolean  @default(false)
  metadata  Json?
  createdAt DateTime @default(now())
}

model PeerReviewAssignment {
  id           String     @id @default(cuid())
  assignmentId String     @unique
  assignment   Assignment @relation(fields: [assignmentId], references: [id])
  rubric       Json
}

model PeerReview {
  id           String     @id @default(cuid())
  reviewerId   String
  reviewer     User       @relation("Reviewer", fields: [reviewerId], references: [id])
  submissionId String
  submission   Submission @relation(fields: [submissionId], references: [id])
  scores       Json?
  comments     String?
  completedAt  DateTime?

  @@unique([reviewerId, submissionId])
}

model ConceptCache {
  id         String   @id @default(cuid())
  userId     String
  concept    String
  suggestion String
  cachedAt   DateTime @default(now())

  @@unique([userId, concept])
}
